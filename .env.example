# === REQUIRED ===
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# === DATABASE (Docker provides these — don't change unless custom setup) ===
DATABASE_URL=postgresql+asyncpg://infera:infera_pass@localhost:5433/infera_db
REDIS_URL=redis://localhost:6379/0

# === OPTIONAL ===
OMIUM_API_KEY=your_omium_api_key_here
OMIUM_WORKSPACE=infera

# === DELIVERY (after Scribe — optional channels) ===
# SendGrid: full exec brief email
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=infera@yourdomain.com
CEO_EMAIL=ceo@yourcompany.com
# Slack Incoming Webhook — short summary + preview when a report completes
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Slack Events API — channel messages enqueue the pipeline: POST /webhooks/slack/events
# Slack app → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=
# Optional: comma-separated channel IDs only (e.g. C012ABC); empty = accept all subscribed channels
SLACK_INGRESS_CHANNEL_IDS=

# Generic HTTPS POST (JSON) — Zapier, Discord, etc. on report completion
OUTBOUND_WEBHOOK_URL=

# === APP CONFIG ===
DEMO_MODE=false
LOG_LEVEL=INFO
MAX_TOKENS_PER_WORKFLOW=500000
MAX_COST_PER_WORKFLOW=2.00
