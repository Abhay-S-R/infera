# === REQUIRED ===
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# === DATABASE (Docker provides these — don't change unless custom setup) ===
DATABASE_URL=postgresql+asyncpg://ascent:ascent_pass@localhost:5433/ascent_db
REDIS_URL=redis://localhost:6379/0

# === OPTIONAL ===
OMIUM_API_KEY=your_omium_api_key_here
OMIUM_WORKSPACE=ascent
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# === DELIVERY (SendGrid — emails CEO exec brief after Scribe) ===
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=ascent@yourdomain.com
CEO_EMAIL=ceo@yourcompany.com

# === APP CONFIG ===
DEMO_MODE=false
LOG_LEVEL=INFO
MAX_TOKENS_PER_WORKFLOW=500000
MAX_COST_PER_WORKFLOW=2.00
